---
import Base from "../layouts/Base.astro";
import StatCard from "../components/StatCard.astro";
import RankBars from "../components/RankBars.astro";
import ManagerChip from "../components/ManagerChip.astro";
import {
  meta, seasons, completedSeasons, allTimeStandings, records,
  managers, getManager, managerColor, managerName, avatarUrl, championPhotos, fmt, pct, record,
} from "../lib/data.js";

// champions per completed season (newest first)
const champs = [...completedSeasons].reverse().map((s) => ({
  season: s,
  champ: seasons[s].champion,
  runnerUp: seasons[s].runnerUp,
  pointsKing: seasons[s].pointsKing,
  photo: championPhotos[s] || null,
}));
const reigning = champs[0];
const pastChamps = champs.slice(1);

// hero facts
const totalGames = allTimeStandings.reduce((a, m) => a + m.allTime.w + m.allTime.l + m.allTime.t, 0);
const totalPoints = allTimeStandings.reduce((a, m) => a + m.allTime.pf, 0);

// records
const topWeek = records.topWeeks[0];
const blowout = records.biggestBlowouts[0];

// longest streaks across all seasons
let bestStreak = { n: 0 }, worstStreak = { n: 0 };
for (const s of completedSeasons)
  for (const r of seasons[s].standings) {
    if (r.bestWinStreak > bestStreak.n) bestStreak = { n: r.bestWinStreak, managerId: r.managerId, teamName: r.teamName, season: s };
    if (r.worstLossStreak > worstStreak.n) worstStreak = { n: r.worstLossStreak, managerId: r.managerId, teamName: r.teamName, season: s };
  }

// leaderboards
const vpBars = [...allTimeStandings]
  .sort((a, b) => b.allTime.vp - a.allTime.vp)
  .map((m) => ({
    name: m.name, value: m.allTime.vp, valueLabel: `${m.allTime.vp} VP`,
    color: managerColor(m.id), href: `/managers/${m.id}`,
    sub: `${record(m.allTime.w, m.allTime.l, m.allTime.t)} · ${pct(m.allTime.winPct)} win`,
  }));
const allPlayBars = [...allTimeStandings].sort((a, b) => b.allTime.allPlayPct - a.allTime.allPlayPct).map((m) => ({
  name: m.name, value: m.allTime.allPlayPct, valueLabel: pct(m.allTime.allPlayPct),
  color: managerColor(m.id), href: `/managers/${m.id}`, sub: "vs. the entire field, every week",
}));

const sections = [
  { href: "/standings", icon: "📊", title: "Standings & Power", desc: "All-play, luck index, efficiency, weekly form — season by season." },
  { href: "/records", icon: "📖", title: "Record Book", desc: "Highest weeks, biggest blowouts, nailbiters, best player seasons ever." },
  { href: "/head-to-head", icon: "⚔️", title: "Head-to-Head", desc: "All-time grid of every rivalry. Who owns who." },
  { href: "/draft", icon: "🎯", title: "Draft Room", desc: "Every board since 2023, plus the biggest steals & busts." },
  { href: "/managers", icon: "👤", title: "Manager Profiles", desc: "Career stats, finishes, and personal record books." },
  { href: "/hall", icon: "🏆", title: "Hall of Fame", desc: "Champions, dynasty trajectory, and the all-time leaderboard." },
  { href: "/labs", icon: "🧪", title: "Labs", desc: "Schedule-swap what-ifs, choke index, boom/bust, coin-flip luck." },
];
---

<Base active="home" description={`The data home of the ${meta.name} dynasty fantasy league.`}>
  <!-- HERO -->
  <section class="hero">
    <div class="wrap hero-inner">
      <div class="hero-pills">
        <span class="chip accent">🏈 Superflex Dynasty · 0.5 PPR</span>
        <span class="chip">12 managers</span>
        <span class="chip gold">{completedSeasons.length} seasons in the books</span>
      </div>
      <h1 class="hero-title">Regular Everday<br /><span class="grad">Normal Guys</span></h1>
      <p class="hero-sub">
        Four seasons of receipts. Every score, streak, steal and heartbreak since 2023 —
        turned into the stats your group chat actually argues about.
      </p>
      <div class="hero-stats">
        <div><span class="num">{completedSeasons.length}</span><label>Seasons</label></div>
        <div><span class="num">{fmt(totalGames / 2)}</span><label>Games played</label></div>
        <div><span class="num">{fmt(Math.round(totalPoints / 1000))}k</span><label>Total points</label></div>
        <div><span class="num">{topWeek.points.toFixed(0)}</span><label>Highest week ever</label></div>
      </div>
      <div class="row wrap-gap" style="margin-top:26px;gap:10px">
        <a href="/dues" class="btn btn-dues">💵 Pay League Dues</a>
        <a href="/standings" class="btn ghost">Explore the stats →</a>
        <a href="/hall" class="btn ghost">🏆 Hall of Fame</a>
      </div>
    </div>
  </section>

  <!-- CHAMPIONS -->
  <section class="section-sm">
    <div class="wrap">
      <div class="eyebrow">The throne</div>
      <h2 class="section-title" style="font-size:clamp(22px,3vw,30px);margin-bottom:18px">Reigning & Past Champions</h2>

      <!-- reigning champion spotlight -->
      <div class="champ-spotlight">
        <div class="cs-photo">
          {reigning.photo
            ? <img src={reigning.photo} alt={`${reigning.champ.teamName}, ${reigning.season} champion`} />
            : <div class="cs-noimg">🏆</div>}
          <span class="cs-yearbadge">🏆 {reigning.season} Champion</span>
        </div>
        <div class="cs-body">
          <span class="cs-crown">👑 Reigning Champion</span>
          <h3 class="cs-team">{reigning.champ.teamName}</h3>
          <a class="cs-mgr" href={`/managers/${reigning.champ.managerId}`}>
            {avatarUrl(getManager(reigning.champ.managerId)?.avatar) && <img src={avatarUrl(getManager(reigning.champ.managerId)?.avatar)} alt="" />}
            <span>@{getManager(reigning.champ.managerId)?.displayName}</span>
          </a>
          {reigning.runnerUp && (
            <div class="cs-box">
              <div class="cs-box-row cs-box-head"><span>2-week final</span><span>Wk 16</span><span>Wk 17</span><span>Total</span></div>
              <div class="cs-box-row cs-win">
                <span class="cs-bt">🏆 {reigning.champ.teamName}</span>
                <span>{fmt(reigning.champ.wk[16], 1)}</span><span>{fmt(reigning.champ.wk[17], 1)}</span><span class="cs-tot">{fmt(reigning.champ.total, 1)}</span>
              </div>
              <div class="cs-box-row">
                <span class="cs-bt">{reigning.runnerUp.teamName}</span>
                <span>{fmt(reigning.runnerUp.wk[16], 1)}</span><span>{fmt(reigning.runnerUp.wk[17], 1)}</span><span class="cs-tot">{fmt(reigning.runnerUp.total, 1)}</span>
              </div>
            </div>
          )}
          {reigning.champ.mvp && (
            <div class="cs-mvp">
              <span class="cs-mvp-badge">🏅 Finals MVP</span>
              <strong>{reigning.champ.mvp.name}</strong>
              {reigning.champ.mvp.pos && <span class={`tag-pos pos-${reigning.champ.mvp.pos}`}>{reigning.champ.mvp.pos}</span>}
              <span class="cs-mvp-pts">{fmt(reigning.champ.mvp.points, 1)} pts</span>
            </div>
          )}
          {reigning.runnerUp && (
            <p class="cs-story">A <strong>#{reigning.champ.seed}-seed</strong> Cinderella run — the lowest seed to ever take the crown.</p>
          )}
          <a href="/hall" class="cs-link">Full championship history →</a>
        </div>
      </div>

      <!-- past champions -->
      {pastChamps.length > 0 && (
        <>
          <h4 class="past-head">Before them</h4>
          <div class="grid cols-2">
            {pastChamps.map(({ season, champ }) => (
              <div class="champ-card">
                <div class="cc-top">
                  <span class="cc-season num">🏆 {season}</span>
                  <span class="chip gold" style="font-size:11px">Champion</span>
                </div>
                <ManagerChip id={champ.managerId} name={champ.teamName} size={38} sub={`#${champ.seed} seed · ${fmt(champ.total)} finals pts`} />
                <div class="cc-foot dim">
                  Beat <strong style="color:var(--text)">{seasons[season].runnerUp?.teamName || "the field"}</strong> in the final
                </div>
              </div>
            ))}
          </div>
        </>
      )}
      <p class="dim" style="font-size:12.5px;margin-top:14px">{meta.note}</p>
    </div>
  </section>

  <!-- BY THE NUMBERS -->
  <section class="section-sm">
    <div class="wrap">
      <div class="eyebrow">By the numbers</div>
      <h2 class="section-title" style="font-size:clamp(22px,3vw,30px);margin:6px 0 18px">League Lore</h2>
      <div class="grid cols-4">
        <StatCard label="Highest score ever" value={topWeek.points.toFixed(1)} accent="accent"
          icon="🔥" sub={`${topWeek.teamName} · ${topWeek.season} Wk ${topWeek.week}`} />
        <StatCard label="Biggest blowout" value={`+${blowout.margin.toFixed(0)}`} accent="hot"
          icon="💥" sub={`${blowout.teamName} · ${blowout.season} Wk ${blowout.week}`} />
        <StatCard label="Longest win streak" value={bestStreak.n} unit="W" accent="gold"
          icon="📈" sub={`${bestStreak.teamName} · ${bestStreak.season}`} />
        <StatCard label="Longest skid" value={worstStreak.n} unit="L" accent="purple"
          icon="🧊" sub={`${worstStreak.teamName} · ${worstStreak.season}`} />
      </div>
    </div>
  </section>

  <!-- LEADERBOARDS -->
  <section class="section-sm">
    <div class="wrap grid cols-2">
      <div class="panel panel-pad">
        <div class="row between" style="margin-bottom:6px">
          <h3 style="font-size:18px">All-Time Victory Points</h3>
          <a href="/hall" class="chip">Full board →</a>
        </div>
        <p class="dim" style="font-size:12.5px;margin:0 0 14px">+2 for each weekly win, plus scoring bonuses — the league's true standings metric.</p>
        <RankBars items={vpBars} />
      </div>
      <div class="panel panel-pad">
        <div class="row between" style="margin-bottom:6px">
          <h3 style="font-size:18px">True Power (All-Play %)</h3>
          <a href="/standings" class="chip">Why this matters →</a>
        </div>
        <p class="dim" style="font-size:12.5px;margin:0 0 14px">Win rate if everyone played everyone, every week — luck stripped out.</p>
        <RankBars items={allPlayBars} />
      </div>
    </div>
  </section>

  <!-- SECTION NAV -->
  <section class="section">
    <div class="wrap">
      <div class="eyebrow">Dig in</div>
      <h2 class="section-title" style="font-size:clamp(22px,3vw,30px);margin:6px 0 18px">Explore the Vault</h2>
      <div class="grid cols-3 navcards">
        {sections.map((s) => (
          <a href={s.href} class="navcard">
            <span class="nc-icon">{s.icon}</span>
            <span class="nc-title">{s.title}</span>
            <span class="nc-desc">{s.desc}</span>
            <span class="nc-go">Open →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <style>
    .hero { padding: 64px 0 38px; position: relative; overflow: hidden; }
    .hero-pills { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 22px; }
    .hero-title { font-size: clamp(44px, 9vw, 92px); line-height: 0.92; letter-spacing: -0.03em; }
    .grad {
      background: linear-gradient(100deg, var(--accent), var(--accent-2) 60%, var(--purple));
      -webkit-background-clip: text; background-clip: text; color: transparent;
    }
    .hero-sub { font-size: clamp(15px, 2vw, 18px); color: var(--muted); max-width: 56ch; margin: 22px 0 0; }
    .btn-dues { background: linear-gradient(100deg, var(--gold), var(--orange)); color: #2a1d00; }
    .btn-dues:hover { box-shadow: 0 8px 22px -8px rgba(255, 207, 74, 0.6); }
    .hero-stats { display: flex; gap: 38px; flex-wrap: wrap; margin-top: 30px; }
    .hero-stats > div { display: flex; flex-direction: column; }
    .hero-stats .num { font-size: clamp(28px, 4vw, 40px); font-weight: 700; line-height: 1; }
    .hero-stats label { font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: .08em; margin-top: 6px; }

    /* reigning champion spotlight */
    .champ-spotlight {
      display: grid; grid-template-columns: minmax(0, 330px) 1fr; gap: 0; margin-bottom: 24px;
      border: 1px solid rgba(255,207,74,.4); border-radius: var(--radius-lg); overflow: hidden;
      background: linear-gradient(120deg, rgba(255,207,74,.12), var(--panel) 52%, var(--bg-2));
      box-shadow: 0 0 0 1px rgba(255,207,74,.12), var(--shadow-lg); position: relative;
    }
    .champ-spotlight::after {
      content: ""; position: absolute; inset: 0; pointer-events: none; z-index: 2;
      background: linear-gradient(115deg, transparent 42%, rgba(255,255,255,.06) 49%, transparent 56%);
      background-size: 250% 100%; animation: shine 6.5s ease-in-out infinite;
    }
    @keyframes shine { 0%, 100% { background-position: 130% 0; } 50% { background-position: -30% 0; } }
    .cs-photo { position: relative; min-height: 380px; background: var(--bg); }
    .cs-photo img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center 40%; display: block; }
    .cs-noimg { display: grid; place-items: center; height: 100%; font-size: 64px; }
    .cs-yearbadge { position: absolute; top: 12px; left: 12px; z-index: 3; background: rgba(8,11,20,.82); color: var(--gold); font-family: var(--display); font-weight: 800; font-size: 13px; padding: 6px 12px; border-radius: 999px; border: 1px solid rgba(255,207,74,.4); backdrop-filter: blur(4px); }
    .cs-body { padding: 26px 28px; display: flex; flex-direction: column; justify-content: center; gap: 11px; position: relative; z-index: 1; }
    .cs-crown { font-size: 12px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; color: var(--gold); }
    .cs-team { font-family: var(--display); font-size: clamp(24px, 3.4vw, 34px); line-height: 1.05; margin: 0; }
    .cs-mgr { display: inline-flex; align-items: center; gap: 8px; font-size: 13px; color: var(--muted); width: fit-content; }
    .cs-mgr img { width: 24px; height: 24px; border-radius: 50%; object-fit: cover; }
    .cs-mgr:hover { color: var(--text); }
    .cs-box { border: 1px solid var(--line); border-radius: 10px; overflow: hidden; font-variant-numeric: tabular-nums; margin: 2px 0; }
    .cs-box-row { display: grid; grid-template-columns: 1fr 50px 50px 56px; align-items: center; gap: 4px; padding: 7px 11px; font-size: 13px; }
    .cs-box-row + .cs-box-row { border-top: 1px solid var(--line); }
    .cs-box-head { background: var(--bg-2); font-size: 9.5px; text-transform: uppercase; letter-spacing: .04em; color: var(--muted); }
    .cs-box-row span:not(.cs-bt) { text-align: right; }
    .cs-win { background: var(--gold-soft); }
    .cs-bt { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-weight: 600; }
    .cs-win .cs-bt { color: var(--gold); }
    .cs-tot { font-weight: 800; }
    .cs-win .cs-tot { color: var(--gold); }
    .cs-mvp { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; font-size: 13.5px; background: var(--bg-2); border: 1px solid var(--line); border-radius: 10px; padding: 9px 12px; }
    .cs-mvp-badge { font-size: 10.5px; font-weight: 800; text-transform: uppercase; letter-spacing: .04em; color: var(--gold); white-space: nowrap; }
    .cs-mvp strong { font-size: 14px; }
    .cs-mvp-pts { margin-left: auto; font-weight: 800; color: var(--gold); font-variant-numeric: tabular-nums; white-space: nowrap; }
    .cs-story { font-size: 14px; line-height: 1.55; color: var(--text-2); margin: 0; }
    .cs-story strong { color: var(--gold); }
    .cs-link { font-size: 13px; color: var(--gold); font-weight: 700; width: fit-content; }
    .cs-link:hover { text-decoration: underline; }
    @media (max-width: 760px) { .champ-spotlight { grid-template-columns: 1fr; } .cs-photo { min-height: 0; aspect-ratio: 4 / 5; } }

    .past-head { font-size: 13px; text-transform: uppercase; letter-spacing: .06em; color: var(--muted); margin: 0 0 12px; font-weight: 700; }
    .champ-card {
      background: linear-gradient(180deg, var(--panel), var(--bg-2));
      border: 1px solid var(--line); border-radius: var(--radius); padding: 18px;
      display: flex; flex-direction: column; gap: 12px;
    }
    .cc-top { display: flex; align-items: center; justify-content: space-between; }
    .cc-season { font-size: 18px; font-weight: 700; color: var(--gold); font-family: var(--display); }
    .cc-foot { font-size: 12px; border-top: 1px solid var(--line); padding-top: 11px; }

    .navcards .navcard {
      display: flex; flex-direction: column; gap: 7px; padding: 22px;
      background: linear-gradient(180deg, var(--panel), var(--bg-2));
      border: 1px solid var(--line); border-radius: var(--radius);
      transition: transform .14s, border-color .14s;
    }
    .navcard:hover { transform: translateY(-3px); border-color: var(--line-2); }
    .nc-icon { font-size: 26px; }
    .nc-title { font-family: var(--display); font-weight: 700; font-size: 17px; }
    .nc-desc { font-size: 13px; color: var(--muted); line-height: 1.45; }
    .nc-go { font-size: 13px; font-weight: 600; color: var(--accent); margin-top: 4px; }
  </style>
</Base>
