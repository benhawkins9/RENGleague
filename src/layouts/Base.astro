---
import "../styles/global.css";
import { meta } from "../lib/data.js";

const { title, description, active } = Astro.props;
const pageTitle = title ? `${title} · ${meta.name}` : meta.name;
const nav = [
  { href: "/", label: "Home", key: "home" },
  { href: "/live", label: "Live", key: "live" },
  { href: "/standings", label: "Standings", key: "standings" },
  { href: "/records", label: "Records", key: "records" },
  { href: "/head-to-head", label: "H2H", key: "h2h" },
  { href: "/draft", label: "The Wire", key: "draft" },
  { href: "/trades", label: "Trades", key: "trades" },
  { href: "/managers", label: "Managers", key: "managers" },
  { href: "/hall", label: "Hall", key: "hall" },
  { href: "/awards", label: "Awards", key: "awards" },
  { href: "/chat", label: "Chat Lab", key: "chat" },
  { href: "/dynasty", label: "Dynasty", key: "dynasty" },
  { href: "/labs", label: "Labs", key: "labs" },
  { href: "/dues", label: "💵 Dues", key: "dues" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description || `Stats, records & dynasty history for the ${meta.name} fantasy league.`} />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E%F0%9F%8F%88%3C/text%3E%3C/svg%3E" />
  </head>
  <body>
    <header class="nav">
      <div class="wrap nav-inner">
        <a href="/" class="brand">
          <span class="brand-mark">🏈</span>
          <span class="brand-text">
            <strong>Regular Everday Normal Guys</strong>
            <em>Dynasty · est. 2023</em>
          </span>
        </a>
        <button class="nav-toggle" id="navToggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="navLinks">
          <span class="nt-bar"></span><span class="nt-bar"></span><span class="nt-bar"></span>
        </button>
        <nav class="nav-links" id="navLinks">
          {nav.map((n) => (
            <a href={n.href} class={`nav-link${active === n.key ? " is-active" : ""}`}>{n.label}</a>
          ))}
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="wrap">
        <div class="row between wrap-gap" style="gap:16px">
          <div>
            <strong style="font-family:var(--display)">Regular Everday Normal Guys</strong>
            <p class="dim" style="font-size:13px;margin:6px 0 0;max-width:46ch">{meta.note}</p>
          </div>
          <div class="dim" style="font-size:13px;text-align:right">
            <p style="margin:0">Data via the Sleeper API · 2023–2026</p>
            <p style="margin:6px 0 0">Built as a static Astro site ⚡</p>
          </div>
        </div>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const t = document.getElementById("navToggle");
        const l = document.getElementById("navLinks");
        if (!t || !l) return;
        const close = () => { l.classList.remove("open"); t.classList.remove("open"); t.setAttribute("aria-expanded", "false"); };
        t.addEventListener("click", (e) => {
          e.stopPropagation();
          const open = l.classList.toggle("open");
          t.classList.toggle("open", open);
          t.setAttribute("aria-expanded", String(open));
        });
        l.querySelectorAll("a").forEach((a) => a.addEventListener("click", close));
        document.addEventListener("click", (e) => { if (!l.contains(e.target) && !t.contains(e.target)) close(); });
        document.addEventListener("keydown", (e) => { if (e.key === "Escape") close(); });
      })();
    </script>

    <style>
      /* ---- mobile-first: sticky top bar + hamburger dropdown ---- */
      .nav {
        position: sticky; top: 0; z-index: 50;
        background: rgba(8, 11, 20, 0.85); backdrop-filter: blur(14px);
        border-bottom: 1px solid var(--line);
      }
      .nav-inner { display: flex; align-items: center; justify-content: space-between; height: 62px; gap: 14px; }
      .brand { display: flex; align-items: center; gap: 11px; flex-shrink: 0; }
      .brand-mark { font-size: 26px; filter: drop-shadow(0 3px 6px rgba(0,0,0,.5)); }
      .brand-text { display: flex; flex-direction: column; line-height: 1.1; }
      .brand-text strong { font-family: var(--display); font-size: 14px; letter-spacing: -0.01em; }
      .brand-text em { font-style: normal; font-size: 11px; color: var(--muted); letter-spacing: 0.04em; }
      .nav-link { padding: 12px 14px; border-radius: 10px; font-size: 15px; font-weight: 600; color: var(--muted); white-space: nowrap; transition: color .15s, background .15s; }
      .nav-link:hover { color: var(--text); background: var(--panel-2); }
      .nav-link.is-active { color: var(--accent); background: var(--accent-soft); }
      .nav-toggle { display: flex; flex-direction: column; gap: 5px; background: var(--panel-2); border: 1px solid var(--line-2); border-radius: 10px; padding: 10px 9px; cursor: pointer; flex-shrink: 0; }
      .nt-bar { width: 20px; height: 2px; background: var(--text); border-radius: 2px; transition: transform .22s, opacity .2s; }
      .nav-toggle.open .nt-bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
      .nav-toggle.open .nt-bar:nth-child(2) { opacity: 0; }
      .nav-toggle.open .nt-bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
      .nav-links {
        position: absolute; top: 100%; left: 0; right: 0;
        display: flex; flex-direction: column; align-items: stretch; gap: 2px;
        background: var(--bg-2); border-bottom: 1px solid var(--line);
        overflow: hidden; max-height: 0; opacity: 0; pointer-events: none; padding: 0 14px;
        transition: max-height .28s ease, opacity .2s, padding .2s; box-shadow: var(--shadow-lg);
      }
      .nav-links.open { max-height: 84vh; opacity: 1; pointer-events: auto; overflow-y: auto; padding: 10px 14px 16px; }
      .footer { border-top: 1px solid var(--line); margin-top: 40px; padding: 34px 0 48px; background: var(--bg-2); }

      /* ---- desktop (>=1100px): fixed left sidebar ---- */
      @media (min-width: 1100px) {
        .nav { position: fixed; inset: 0 auto 0 0; width: 230px; background: var(--bg-2); border-right: 1px solid var(--line); border-bottom: none; overflow-y: auto; }
        .nav .nav-inner { flex-direction: column; align-items: stretch; justify-content: flex-start; height: auto; max-width: none; width: 100%; margin: 0; padding: 22px 14px 28px; gap: 0; }
        .brand { margin: 0 6px 22px; }
        .brand-text strong { font-size: 15px; white-space: normal; }
        .nav-toggle { display: none; }
        .nav-links { position: static; max-height: none; opacity: 1; pointer-events: auto; overflow: visible; gap: 3px; background: none; border: none; box-shadow: none; padding: 0; }
        .nav-link { padding: 9px 12px; font-size: 14px; }
        main, .footer { margin-left: 230px; }
      }
    </style>
  </body>
</html>
