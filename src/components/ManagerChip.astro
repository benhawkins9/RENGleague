---
import { getManager, avatarUrl, managerColor } from "../lib/data.js";
const { id, name, sub, size = 30, link = true, mono = false } = Astro.props;
const m = getManager(id);
const display = name || m?.name || "Unknown";
const av = avatarUrl(m?.avatar);
const color = managerColor(id);
const Tag = link && id ? "a" : "div";
const href = link && id ? `/managers/${id}` : undefined;
---
<Tag href={href} class="mchip" style={`--mc:${color}`}>
  <span class="mc-av" style={`width:${size}px;height:${size}px`}>
    {av ? <img src={av} alt="" loading="lazy" /> : <span class="mc-fallback">{display.charAt(0)}</span>}
  </span>
  <span class="mc-text">
    <span class={`mc-name${mono ? " num" : ""}`}>{display}</span>
    {sub && <span class="mc-sub">{sub}</span>}
  </span>
</Tag>
<style>
  .mchip { display: inline-flex; align-items: center; gap: 9px; min-width: 0; }
  a.mchip:hover .mc-name { color: var(--mc); }
  .mc-av {
    flex-shrink: 0; border-radius: 8px; overflow: hidden; display: grid; place-items: center;
    background: var(--panel-3); border: 1px solid var(--line); box-shadow: inset 0 0 0 1.5px color-mix(in srgb, var(--mc) 35%, transparent);
  }
  .mc-av img { width: 100%; height: 100%; object-fit: cover; }
  .mc-fallback { font-family: var(--display); font-weight: 700; color: var(--mc); font-size: 13px; }
  .mc-text { display: flex; flex-direction: column; line-height: 1.15; min-width: 0; }
  .mc-name { font-weight: 600; font-size: 14px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; transition: color .15s; }
  .mc-sub { font-size: 11.5px; color: var(--muted); }
</style>
