---
// A highlight stat card: big value + label + optional context line.
// `info` adds a hover-tooltip "ⓘ" that explains what the metric means.
const { label, value, unit, sub, accent = "accent", icon, href, info } = Astro.props;
const Tag = href ? "a" : "div";
---
<Tag href={href} class={`statcard accent-${accent}`}>
  <div class="sc-top">
    <span class="sc-label">{label}{info && <span class="sc-info" title={info} tabindex="0">ⓘ</span>}</span>
    {icon && <span class="sc-icon">{icon}</span>}
  </div>
  <div class="sc-value num">
    {value}{unit && <span class="sc-unit">{unit}</span>}
  </div>
  {sub && <div class="sc-sub">{sub}</div>}
  <slot />
</Tag>
<style>
  .statcard {
    display: block; background: linear-gradient(180deg, var(--panel), var(--bg-2));
    border: 1px solid var(--line); border-radius: var(--radius); padding: 18px 18px 16px;
    position: relative; overflow: hidden; transition: transform .14s, border-color .14s;
  }
  .statcard::before {
    content: ""; position: absolute; inset: 0 0 auto 0; height: 3px;
    background: var(--bar, var(--accent)); opacity: .9;
  }
  a.statcard:hover { transform: translateY(-2px); border-color: var(--line-2); }
  .accent-accent { --bar: var(--accent); }
  .accent-blue { --bar: var(--accent-2); }
  .accent-gold { --bar: var(--gold); }
  .accent-hot { --bar: var(--hot); }
  .accent-purple { --bar: var(--purple); }
  .accent-orange { --bar: var(--orange); }
  .sc-top { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
  .sc-label { font-size: 11.5px; font-weight: 600; text-transform: uppercase; letter-spacing: .08em; color: var(--muted); }
  .sc-info { margin-left: 5px; font-size: 11px; color: var(--faint); cursor: help; border-radius: 50%; transition: color .15s; }
  .sc-info:hover, .sc-info:focus { color: var(--accent); outline: none; }
  .sc-icon { font-size: 17px; opacity: .85; }
  .sc-value { font-size: clamp(26px, 4.5vw, 36px); font-weight: 700; margin-top: 8px; line-height: 1; color: var(--bar); }
  .sc-unit { font-size: 15px; color: var(--muted); margin-left: 3px; font-weight: 500; }
  .sc-sub { font-size: 12.5px; color: var(--muted); margin-top: 7px; }
</style>
